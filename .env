# 东方财富API Cookie
# 用于访问东方财富接口时的身份验证
# 注意: Cookie会过期,需要定期更新
VITE_EASTMONEY_COOKIE=

# User-Agent配置
VITE_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/111.0.0.0 Safari/537.36

# HTTP请求头配置
VITE_ACCEPT=*/*
VITE_ACCEPT_LANGUAGE=zh-CN,zh;q=0.9

# API代理配置 - Referer和Origin
VITE_SINA_REFERER=https://finance.sina.com.cn
VITE_SINA_ORIGIN=https://finance.sina.com.cn
VITE_TENCENT_REFERER=https://finance.qq.com
VITE_TENCENT_ORIGIN=https://finance.qq.com
VITE_TENCENT_RANK_REFERER=https://finance.qq.com
VITE_TENCENT_RANK_ORIGIN=https://finance.qq.com
VITE_KLINE_REFERER=https://proxy.finance.qq.com
VITE_KLINE_ORIGIN=https://proxy.finance.qq.com
VITE_EASTMONEY_REFERER=https://data.eastmoney.com
VITE_EASTMONEY_ORIGIN=https://data.eastmoney.com
